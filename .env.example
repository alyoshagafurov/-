# ── Secrets ────────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── База данных ────────────────────────────────────────────
# По умолчанию SQLite (файл data/app.db). Для прода — PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@db:5432/photoclean
DATABASE_URL=sqlite:///./data/app.db

# ── Первый администратор (создаётся при первом запуске seed) ─
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ── Парсер ─────────────────────────────────────────────────
# Сколько фото качать параллельно
PARSER_MAX_WORKERS=8
# Сколько пикселей срезать снизу (водяной знак Avito)
PARSER_WATERMARK_CROP=48
# Таймаут запроса к Avito / CDN, секунды
PARSER_TIMEOUT=30
# Прокси (через запятую). Формат: http://user:pass@host:port  или  http://host:port
# Пусто = без прокси. Пример: PARSER_PROXIES=http://1.2.3.4:8000,http://5.6.7.8:8000
PARSER_PROXIES=

# ── Регистрация по умолчанию ───────────────────────────────
# Сколько бесплатных обработок даётся новому пользователю
DEFAULT_FREE_LIMIT=3
# На сколько дней действует бесплатный доступ
DEFAULT_FREE_DAYS=7
